{
    "name": "brunocfalcao/eduka-nereus",
    "description": "Eduka Nereus - Site features for Eduka LMS",
    "keywords": [
        "brunocfalcao",
        "eduka"
    ],
    "homepage": "https://github.com/brunocfalcao/eduka-nereus",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Bruno Falcão",
            "email": "bruno.c.falcao@brunofalcao.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^7.4|^8.0",
        "brunocfalcao/eduka-cube": "dev-master",
        "brunocfalcao/eduka-nova": "dev-master",
        "brunocfalcao/eduka-maquillage": "dev-master",
        "brunocfalcao/eduka-analytics": "dev-master",
        "spatie/laravel-honeypot": "^3.0",
        "imliam/laravel-blade-helper": "^1.4"        
    },
    "autoload": {
        "psr-4": {
            "Eduka\\Nereus\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Eduka\\Nereus\\EdukaNereusServiceProvider"
            ]
        }
    }
}
